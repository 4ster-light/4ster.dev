{
  "main": "dist/_worker.js/index.js",
  "name": "aster",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "kv_namespaces": [{ "binding": "SESSION" }],
  "observability": {
    "enabled": true
  },
  "workers_dev": false,
  "preview_urls": false
}
