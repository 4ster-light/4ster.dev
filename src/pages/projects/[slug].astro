---
import leftArrowsIcon from "../../icons/LeftArrows.svg?url"
import loveIcon from "../../icons/Love.svg?url"
import BaseLayout from "../../layouts/BaseLayout.astro"
import ButtonLink from "../../components/ButtonLink.astro"
import ReposCard from "../../components/ReposCard.astro"
import { fetchProjectReadme, fetchProjects } from "../../lib/projects.ts"
import site, { ogImage } from "../../lib/site.ts"

export const prerender = true

export const getStaticPaths = async () => {
  const githubToken = globalThis.process?.env?.GH_API ?? ""
  const repositories = await fetchProjects(githubToken)

  return await Promise.all(
    repositories.map(async (repository) => {
      const [owner, repoName] = repository.full_name.split("/")
      const readme = await fetchProjectReadme(owner ?? "", repoName ?? "", githubToken)

      return {
        params: { slug: repository.name },
        props: { repository: { ...repository, readme } }
      }
    })
  )
}

const repository = Astro.props.repository

if (!repository) {
  return Astro.redirect("/projects")
}

const description = repository.description || `${repository.name} - Open source project`
const canonicalUrl = `${site.baseUrl}/projects/${repository.name}`
---

<BaseLayout
  title={`${repository.name} | Aster`}
  {description}
  ogTitle={repository.name}
  ogDescription={description}
  ogUrl={canonicalUrl}
  {canonicalUrl}
  ogImage={ogImage(repository.name, {
    subtitle: description,
    type: "project"
  })}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: site.baseUrl },
        { "@type": "ListItem", position: 2, name: "Projects", item: `${site.baseUrl}/projects` },
        { "@type": "ListItem", position: 3, name: repository.name, item: canonicalUrl }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: repository.name,
      url: canonicalUrl,
      description
    }
  ]}
>
  <article class="flex flex-col gap-8">
    <h1 class="text-3xl font-bold text-secondary">{repository.name}</h1>
    <p class="text-base-content/70">{description}</p>
    <h2 class="text-xl font-bold">Repository Information</h2>
    <div class="overflow-x-auto">
      <table class="table table-xs sm:table-sm border border-base-200">
        <tbody>
          <tr>
            <th class="text-left">Language</th>
            <td>{repository.language || "Not specified"}</td>
          </tr>
          <tr>
            <th class="text-left">Stars</th>
            <td>{repository.stars}</td>
          </tr>
          <tr>
            <th class="text-left">Forks</th>
            <td>{repository.forks}</td>
          </tr>
          <tr>
            <th class="text-left">Last Updated</th>
            <td>{repository.updated_at}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <a
      href={repository.url}
      target="_blank"
      rel="noopener"
      class="btn w-full"
    >View on GitHub</a>

    <section
      class="prose prose-sm sm:prose-base card card-border rounded-2xl p-4 sm:p-8 bg-info/5 overflow-hidden"
      set:html={repository.readme || ""}
    />

    <ReposCard />

    <footer
      class="flex justify-between items-center gap-4 flex-col sm:flex-row"
    >
      <div class="flex gap-2 sm:ml-auto">
        <ButtonLink href={site.projects} target="" ariaLabel="Back to projects">
          <img
            src={leftArrowsIcon}
            alt=""
            width="32"
            height="32"
            decoding="async"
            class="size-8"
          />
        </ButtonLink>
        <ButtonLink href={site.donate} ariaLabel="Sponsor me">
          <img
            src={loveIcon}
            alt=""
            width="24"
            height="24"
            decoding="async"
            class="size-6"
          /> Sponsor
        </ButtonLink>
      </div>
    </footer>
  </article>
</BaseLayout>
