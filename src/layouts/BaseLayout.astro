---
import "../../assets/styles/app.css"
import codeIcon from "../../assets/icons/Code.svg?url"
import linkIcon from "../../assets/icons/Link.svg?url"
import loveIcon from "../../assets/icons/Love.svg?url"
import NavLink from "../components/NavLink.astro"
import site from "../lib/site.ts"

interface Props {
  title?: string
  description?: string
  ogTitle?: string
  ogDescription?: string
  ogType?: "website" | "article"
  ogUrl?: string
  ogImage?: string
}

const {
  title = "✰λster✰",
  description = "Personal blog about programming, technology, and computer science.",
  ogTitle = title,
  ogDescription = description,
  ogType = "website",
  ogUrl = site.baseUrl,
  ogImage
} = Astro.props

const navLinks = [
  {
    href: site.bio,
    label: "Link Tree",
    icon: linkIcon
  },
  {
    href: site.projects,
    label: "Projects",
    icon: codeIcon,
    target: ""
  },
  {
    href: site.donate,
    label: "Support Me",
    icon: loveIcon,
    target: ""
  }
]
---

<html lang="en" data-theme="teal_dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1419" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f5fafa" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark light" />
    <meta name="description" content={description} />
    <meta name="author" content="David Vivar Bogónez" />

    <meta property="og:title" content={ogTitle} />
    <meta property="og:type" content={ogType} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:site_name" content="✰λster✰" />
    <meta property="og:locale" content="en_US" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@4ster_light" />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {ogImage && <meta property="twitter:image:height" content="600" />}
    {ogImage && <meta property="twitter:image:width" content="1200" />}

    <title>{title}</title>
    <link rel="icon" href="/pfp.jpg" />
    <link rel="preconnect" href="https://github.com" />
    <link rel="preconnect" href="https://avatars.githubusercontent.com" />
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content">
    <header class="border-b border-base-300 bg-base-200/30">
      <nav class="max-w-4xl mx-auto p-4 lg:px-0 flex flex-col md:flex-row items-center justify-center md:justify-between gap-4">
        <a href={site.url} class="text-3xl link-hover font-bold text-secondary">✰λster✰</a>

        <div class="flex flex-wrap items-center justify-center md:justify-end gap-2">
          {navLinks.map((entry) => <NavLink {...entry} />)}
        </div>
      </nav>
    </header>

    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:btn focus:btn-primary">
      Skip to content
    </a>

    <main id="main-content" class="max-w-4xl mx-auto p-4 sm:p-8 lg:px-0 flex-1 w-full">
      <slot />
    </main>

    <footer class="border-t border-base-300 bg-base-200/40">
      <div class="max-w-4xl mx-auto py-4 text-center text-base-content/70">
        <p>© {new Date().getFullYear()} ✰λster✰</p>
      </div>
    </footer>
  </body>
</html>
