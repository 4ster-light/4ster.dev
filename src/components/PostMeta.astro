---
interface PostData {
  slug?: string
  title: string
  description: string
  date: string
  lang?: "en" | "es"
  tags?: string[]
}

interface Props {
  post: PostData
  header?: boolean
}

const { post, header = false } = Astro.props
const langLabel = post.lang === "es" ? "ES" : "EN"
const href = post.slug ? `/${post.lang || "en"}/posts/${post.slug}` : "/"
---

<header class={`flex flex-col ${header ? "gap-4" : "gap-2 border-l-2 border-primary pl-4"}`}>
  <div class="flex items-start justify-between gap-3 flex-wrap">
    {header ? <h1 class="text-3xl md:text-4xl font-bold">{post.title}</h1> : (
       <a {href} class="link link-hover link-primary">
         <h3 class="text-lg">{post.title}</h3>
       </a>
     )}

    <span class="badge badge-soft badge-secondary">{langLabel}</span>
  </div>

  <p class="text-base-content/70 text-sm leading-relaxed">{post.description}</p>

  <time datetime={post.date}>
    {new Date(post.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric"
    })}
  </time>

  <div class="flex gap-2 flex-wrap m-0">
    {post.tags?.length ? post.tags.map((tag) => (
      <span class="badge badge-soft badge-info">{tag}</span>
    )) : <span class="badge badge-soft badge-info">UNCATEGORISED</span>}
  </div>
</header>
